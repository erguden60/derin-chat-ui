{
  "name": "derin-chat-ui",
  "version": "1.0.11",
  "description": "Production-grade embeddable AI chat SDK - Built for developers who need reliable chat infrastructure",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./umd": "./dist/index.umd.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai-chat",
    "chatbot-sdk",
    "chat-widget",
    "preact",
    "typescript",
    "websocket",
    "realtime-chat",
    "file-upload",
    "ai-assistant",
    "chat-ui",
    "conversational-ai",
    "embedding-sdk",
    "gpt-chat",
    "llm-interface"
  ],
  "author": "Emirhan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/erguden60/derin-chat-ui.git"
  },
  "bugs": {
    "url": "https://github.com/erguden60/derin-chat-ui/issues"
  },
  "homepage": "https://github.com/erguden60/derin-chat-ui#readme",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:demo": "tsc -b && vite build -c vite.config.demo.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,scss,css}\"",
    "prepublishOnly": "npm run test && npm run build",
    "prepare": "husky"
  },
  "peerDependencies": {
    "preact": ">=10.0.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/ui": "^4.0.17",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-preact": "^0.1.0",
    "globals": "^17.2.0",
    "happy-dom": "^20.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "preact": "^10.27.2",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass": "^1.97.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.17"
  }
}
